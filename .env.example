# ============================================================
# Environment Variables — copy this file to .env for local dev
# All variables below are also required in the Render dashboard
# ============================================================

# ---- Supabase (backend / runtime) ----
# Your Supabase project URL
SUPABASE_URL=https://haxmuzigoywxxbjuiutg.supabase.co
# Your Supabase anon/public key (find it in Supabase → Settings → API)
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Storage bucket name (default is fine unless you renamed it)
SUPABASE_STORAGE_BUCKET=meetings_files_folder

# ---- Supabase (frontend / Vite build-time) ----
# Must match the values above — Vite embeds these at build time
VITE_SUPABASE_URL=https://haxmuzigoywxxbjuiutg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ---- Server ----
# Port used locally; Render overrides this automatically
PORT=3001
NODE_ENV=development
